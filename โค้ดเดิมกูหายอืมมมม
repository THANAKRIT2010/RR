-- 🔍 ฟังก์ชันหาปืน
local function getAllGuns()
    local guns = {}
    local locations = {LocalPlayer.Backpack, LocalPlayer.Character}
    for _, loc in pairs(locations) do
        if loc then
            for _, item in pairs(loc:GetChildren()) do
                if item:IsA("Tool") and (item:FindFirstChild("shot") or item:FindFirstChild("RemoteEvent") or item:FindFirstChild("MainEvent")) then
                    table.insert(guns, item)
                end
            end
        end
    end
    return guns
end

-- 🎯 หาเป้าหมายที่ใกล้ที่สุด
local function getClosestPlayer()
    local closest, dist = nil, _G.ShootRange
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and not isWhitelisted(p) and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local d = (p.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if targetNameSearch ~= "" then
                    if (string.find(string.lower(p.Name), string.lower(targetNameSearch)) or string.find(string.lower(p.DisplayName), string.lower(targetNameSearch))) and d <= _G.ShootRange then
                        return p 
                    end
                elseif d < dist then 
                    dist = d
                    closest = p 
                end
            end
        end
    end
    return closest
end

-- 🔫 ระบบยิง
local function shoot(target, speedBoost)
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    local root = target.Character:FindFirstChild("HumanoidRootPart")
    if not head or not root then return end

    local shootPos = head.Position + (root.Velocity * (_G.Prediction and 0.13 or 0))
    local guns = getAllGuns()

    if #guns > 0 then
        if _G.SilentBagShoot then
            if tick() - lastShotTime >= fireRate then
                for _, g in pairs(guns) do
                    task.spawn(function()
                        local remote = g:FindFirstChild("shot") or g:FindFirstChild("RemoteEvent") or g:FindFirstChild("MainEvent")
                        if remote then remote:FireServer(shootPos) end
                    end)
                end
                lastShotTime = tick()
            end
        elseif _G.LoopSwapShot then
            for _, g in pairs(guns) do
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                    LocalPlayer.Character.Humanoid:EquipTool(g)
                    local remote = g:FindFirstChild("shot") or g:FindFirstChild("RemoteEvent") or g:FindFirstChild("MainEvent")
                    if remote then remote:FireServer(shootPos) end
                    task.wait(0.05)
                end
            end
        elseif _G.BurstMode then
            for _, g in pairs(guns) do
                task.spawn(function()
                    local remote = g:FindFirstChild("shot") or g:FindFirstChild("RemoteEvent") or g:FindFirstChild("MainEvent")
                    if remote and LocalPlayer.Character:FindFirstChild("Humanoid") then
                        LocalPlayer.Character.Humanoid:EquipTool(g)
                        remote:FireServer(shootPos)
                        if speedBoost then remote:FireServer(shootPos) end
                    end
                end)
            end
        end
        if _G.InvisibleGun then
            for _, g in pairs(guns) do
                for _, p in pairs(g:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 1 end end
            end
        end
    end
end

