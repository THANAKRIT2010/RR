-- ฟังก์ชันสร้างปุ่ม Toggle สวยๆ
local function createToggle(text, varName, parent)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, 0, 0, 38); btn.Text = text .. " : OFF"; btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30); btn.TextColor3 = Color3.fromRGB(200, 200, 200); btn.Font = "GothamBold"; btn.TextSize = 12
    Instance.new("UICorner", btn)
    local stroke = Instance.new("UIStroke", btn); stroke.Thickness = 1.5; stroke.Color = Color3.fromRGB(50, 50, 50)

    btn.MouseButton1Click:Connect(function()
        playClickSound()
        _G[varName] = not _G[varName]
        local active = _G[varName]
        btn.Text = text .. (active and " : ON" or " : OFF")
        
        -- Animation
        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = active and Color3.fromRGB(80, 0, 0) or Color3.fromRGB(30, 30, 30),
            TextColor3 = active and Color3.new(1, 1, 1) or Color3.fromRGB(200, 200, 200)
        }):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {
            Color = active and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(50, 50, 50)
        }):Play()
    end)
end

